          <AuxValues>
            <AuxValue name="JavaCodeGenerator_CreateCodeCustom" type="java.lang.String" value="new javax.swing.JPanel() {&#xa;    @Override&#xa;    protected void paintComponent(java.awt.Graphics g) {&#xa;        super.paintComponent(g);&#xa;&#xa;        int size = 9;&#xa;        float cellWidth = (float) getWidth() / (size - 1);&#xa;        float cellHeight = (float) getHeight() / (size - 1);&#xa;&#xa;        g.setColor(java.awt.Color.GRAY);&#xa;&#xa;        for (int i = 0; i &lt; size; i++) {&#xa;&#xa;            int x = Math.round(i * cellWidth);&#xa;            int y = Math.round(i * cellHeight);&#xa;&#xa;            g.drawLine(x, 0, x, getHeight());&#xa;&#xa;            g.drawLine(0, y, getWidth(), y);&#xa;        }&#xa;    } }&#xa;    "/>
          </AuxValues>

